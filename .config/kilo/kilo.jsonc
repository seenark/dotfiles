{
  "$schema": "https://app.kilo.ai/config.json",
  "permission": {
    "bash": {
      "*": "ask",
      "head *": "allow",
      "tail *": "allow",
      "turbo *": "allow",
      "find *": "allow",
      "rm *": "allow",
      "rtk *": "allow",
      "git": "allow",
      "rtk": "allow",
      "npm": "ask",
      "bun": "allow",
      "biome": "allow",
      "tsc": "allow",
      "jq": "allow"
    }
  },
}
